{
  "name": "soloMKT-image-marketplace",
  "version": "1.0.0",
  "description": "Claude Code 插件市场 - AI 图片生成服务集合",
  "owner": {
    "name": "wolf521",
    "url": "https://github.com/wolf521"
  },
  "source": "wolf521/solomkt-image",
  "url": "https://github.com/wolf521/solomkt-image.git",
  "auto_update": false,
  "plugins": [
    {
      "id": "wolf521/solomkt-image",
      "name": "Image Generator",
      "owner": {
        "name": "wolf521",
        "url": "https://github.com/wolf521"
      },
      "description": "基于 GenerateImage API 的 AI 图片生成插件，在 Claude Code 中使用 /generate-image 即可生成图片",
      "version": "1.0.0",
      "path": "plugins/image-generator",
      "category": "image-generation",
      "tags": ["image", "ai", "generate", "图片生成"],
      "icon": "🖼️",
      "install": "/plugin marketplace add wolf521/solomkt-image",
      "download": {
        "url": "https://prompt-manager-uat.issmart.com.cn/plugins/image-generator",
        "files": [
          "commands/generate-image.md",
          "scripts/generate_image.py",
          "hooks/hooks.json",
          ".mcp.json"
        ]
      },
      "requires": {
        "python": ">=3.8"
      },
      "setup": {
        "required": true,
        "description": "首次安装需要提供 API Key 以访问 GenerateImage 服务",
        "steps": [
          {
            "action": "prompt",
            "field": "api_key",
            "label": "API Key",
            "description": "请输入您的 GenerateImage API Key（请联系系统管理员获取）",
            "required": true,
            "secret": true
          }
        ]
      }
    }
  ]
}
